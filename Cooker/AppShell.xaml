<Shell
    x:Class="Cooker.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:Cooker.Pages"
    Shell.BackgroundColor="#FF7043"
    Shell.ForegroundColor="White"
    Shell.TitleColor="White"
    Shell.DisabledColor="Gray"
    Shell.UnselectedColor="#FFE0B2">

    <TabBar>

        <ShellContent
            Title="Home"
            Icon="home.png"
            ContentTemplate="{DataTemplate pages:HomePage}" />

        <ShellContent
            Title="Favorites"
            Icon="favorite.png"
            ContentTemplate="{DataTemplate pages:FavoriteRecipePage}" />

        <ShellContent
            Title="Settings"
            Icon="settings.png"
            ContentTemplate="{DataTemplate pages:SettingsPage}" />

    </TabBar>

</Shell>