<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
             x:Class="Cooker.MainPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="25">
            <Label
            Text="Cooker"
            FontSize="32"
            FontAttributes="Bold"
            HorizontalOptions="Center" />

            <Label
            Text="Cooking guidance for beginners"
            FontSize="16"
            HorizontalOptions="Center" />

            <Button
            x:Name="OpenHomeBtn"
            Text="Open App"
            Clicked="OpenHomeBtn_Clicked" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
