<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Cooker.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ScrollView>

        <FlexLayout
            Direction="Column"
            JustifyContent="SpaceEvenly"
            AlignItems="Center"
            Padding="30">

            <Label
                Text="Cooker"
                FontSize="32"
                FontAttributes="Bold" />

            <Label
                Text="Cooking guidance for beginners"
                FontSize="18" />

            <Button
            Text="Open Recipes"
            Clicked="OpenHomeBtn_Clicked"/>

            <Button
            Text="Notification Settings"
            Clicked="OpenSettings_Clicked"/>

        </FlexLayout>

    </ScrollView>

</ContentPage>
