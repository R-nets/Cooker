<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Cooker"
             x:Class="Cooker.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
                <ResourceDictionary Source="Resources/Styles/CustomStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="PageBackgroundColorLight">#FFFFFF</Color>
            <Color x:Key="PageBackgroundColorDark">#1E1E1E</Color>
            <Color x:Key="PrimaryTextLight">#000000</Color>
            <Color x:Key="PrimaryButtonLight">#00000000</Color>
            <Color x:Key="PrimaryTextDark">#FFFFFF</Color>
            <Color x:Key="PrimaryColor">#FF7043</Color>
            <Color x:Key="SecondaryColor">#FFA270</Color>
            <Color x:Key="DarkBackground">#1E1E1E</Color>
            <Color x:Key="CardDark">#2A2A2A</Color>
            <Color x:Key="BorderColor">#E0E0E0</Color>

            <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="BackgroundColor" Value="#212121"/>
            <Setter Property="TextColor" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="BackgroundColor" Value="White"/>
            <Setter Property="TextColor" Value="Black"/>
            <Setter Property="BorderColor" Value="Black"/>
            <Setter Property="BorderWidth" Value="1"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="BackgroundColor" Value="#D32F2F"/>
            <Setter Property="TextColor" Value="White"/>
        </Style>

        <Style x:Key="CookingAccentButton" TargetType="Button">
            <Setter Property="BackgroundColor" Value="#FF7043"/>
            <Setter Property="TextColor" Value="White"/>
        </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
