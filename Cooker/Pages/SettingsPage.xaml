<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Cooker.Pages.SettingsPage">

    <VerticalStackLayout
        Padding="20"
        Spacing="15">

        <Label
            Text="Settings"
            FontSize="28"
            FontAttributes="Bold"/>

        <HorizontalStackLayout>

            <Label Text="Notifications"/>

            <Switch
                x:Name="NotificationSwitch"
                Toggled="NotificationChanged"/>

        </HorizontalStackLayout>

        <HorizontalStackLayout>

            <Label Text="Timers Vibration"/>
            <Switch
                x:Name="VibrationSwitch"
                Toggled="VibrationChanged"/>

        </HorizontalStackLayout>

    </VerticalStackLayout>

</ContentPage>