<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Cooker.Pages.FavoriteRecipePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Favorite Recipes"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundColorLight},
                                       Dark={StaticResource PageBackgroundColorDark}}">

    <Grid Padding="20">

        <CollectionView 
            x:Name="FavoriteCollection"
            SelectionMode="Single"
            SelectionChanged="RecipeSelected">
            
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="10" Margin="5">
                        <VerticalStackLayout Spacing="8">

                            <Image
                                Source="{Binding ImagePath}"
                                HeightRequest="120"
                                Aspect="AspectFill" />

                            <Label
                                Text="{Binding Name}"
                                FontSize="18"
                                FontAttributes="Bold" 
                                TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                                            Dark={StaticResource PrimaryTextDark}}" />

                            <Label
                                Text="{Binding Cuisine}"
                                TextColor="Gray" />

                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>