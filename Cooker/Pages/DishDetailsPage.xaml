<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns:layouts="clr-namespace:Cooker.Layouts"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Cooker.Pages.DishDetailsPage"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundColorLight},
                                       Dark={StaticResource PageBackgroundColorDark}}">

    <ScrollView>

        <VerticalStackLayout Padding="20" Spacing="15">

            <Image
                x:Name="DishImage"
                HeightRequest="200"
                Aspect="AspectFill"/>

            <Label
                x:Name="DishName"
                FontSize="28"
                FontAttributes="Bold"
                TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                            Dark={StaticResource PrimaryTextDark}}" />

            <Label
                x:Name="CuisineLabel"
                TextColor="Gray"/>

            <Label
                Text="Ingredients"
                FontAttributes="Bold"
                FontSize="18"
                TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                            Dark={StaticResource PrimaryTextDark}}" />

            <Label 
                x:Name="IngredientsLabel"
                TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                            Dark={StaticResource PrimaryTextDark}}" />

            <Label
                Text="Cooking Steps"
                FontAttributes="Bold"
                FontSize="18"
                TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                            Dark={StaticResource PrimaryTextDark}}" />

            <Label 
                x:Name="StepsLabel"
                TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                            Dark={StaticResource PrimaryTextDark}}" />

            <Button
                Text="Copy Recipe Details"
                Clicked="CopyRecipe_Clicked"
                TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                            Dark={StaticResource PrimaryTextDark}}" />

            <Button
                Text="Restart Recipe"
                BackgroundColor="Orange"
                TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                            Dark={StaticResource PrimaryTextDark}}" 
                Clicked="RestartRecipe_Clicked"/>

            <Label
                Text="Timers"
                FontAttributes="Bold"
                FontSize="18"
                TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                            Dark={StaticResource PrimaryTextDark}}" />

            <CollectionView 
                x:Name="TimerCollection">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <layouts:TimerCardView Loaded="TimerCard_Loaded" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

            <Button
                Text="Edit Recipe"
                Clicked="EditRecipe_Clicked"
                TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                            Dark={StaticResource PrimaryTextDark}}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>