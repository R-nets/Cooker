<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Cooker.Pages.CookingStepsPage"
    Title="Steps Page"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundColorLight},
                                       Dark={StaticResource PageBackgroundColorDark}}">

    <Grid>

        <Image
            Source="{Binding BackgroundImage}"
            Aspect="AspectFit"
            Opacity="0.25"
            HorizontalOptions="Center"
            VerticalOptions="Center" />


        <BoxView
            x:Name="BackgroundOverlay"
            InputTransparent="True"
            Opacity="0.6"
            BackgroundColor="{AppThemeBinding Light=White, Dark=Black}" />

        <Grid>
            <ScrollView>

                <VerticalStackLayout Padding="20" Spacing="15">

                    <Button
                        Text="Back"
                        Clicked="OnBackClicked"
                        BackgroundColor="Gray"
                        TextColor="White">

                        <Button.IsVisible>
                            <OnPlatform x:TypeArguments="x:Boolean">
                                <On Platform="WinUI" Value="True" />
                                <On Platform="Android,iOS,MacCatalyst" Value="False" />
                            </OnPlatform>
                        </Button.IsVisible>

                    </Button>

                    <Image
                        x:Name="RecipeImage"
                        HeightRequest="180"
                        Aspect="AspectFill"/>

                    <Button
                        Text="Add Image"
                        Clicked="AddImage_Clicked"/>

                    <Entry
                        x:Name="NameEntry"
                        Placeholder="Recipe Name"/>

                    <Picker 
                        x:Name="CuisinePicker" 
                        Title="Cuisine"
                        TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                                    Dark={StaticResource PrimaryTextDark}}" >

                        <Picker.Items>
                            <x:String>Chinese</x:String>
                            <x:String>Japanese</x:String>
                            <x:String>Italian</x:String>
                            <x:String>Western</x:String>
                            <x:String>Indian</x:String>
                        </Picker.Items>
                    </Picker>

                    <Editor  
                        x:Name="IngredientsEditor"
                        Placeholder="Ingredients"/>

                    <HorizontalStackLayout Spacing="10">

                        <Label Text="Steps:"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                                           Dark={StaticResource PrimaryTextDark}}" />

                        <Stepper x:Name="StepsStepper"
                                 Minimum="1"
                                 Maximum="20"
                                 Increment="1"
                                 ValueChanged="StepsStepper_ValueChanged"/>

                        <Label x:Name="StepsCountLabel"
                               Text="1"
                               VerticalOptions="Center"/>

                    </HorizontalStackLayout>

                    <Label Text="Add Timer for Step" 
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                                       Dark={StaticResource PrimaryTextDark}}" />


                    <CollectionView x:Name="StepCollection">

                        <CollectionView.ItemTemplate>
                            <DataTemplate>

                                <Border Margin="5"
                                        Padding="10"
                                        StrokeThickness="1"
                                        Stroke="{DynamicResource BorderColor}"
                                        StrokeShape="RoundRectangle 10">

                                    <VerticalStackLayout>

                                        <Label Text="{Binding StepIndex, StringFormat='Step {0}'}" 
                                               TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                                                           Dark={StaticResource PrimaryTextDark}}" />

                                        <Entry Placeholder="Description"
                                               Text="{Binding Description}" />

                                        <HorizontalStackLayout>

                                            <Entry 
                                                Placeholder="H" 
                                                WidthRequest="60" 
                                                Text="{Binding Hours}" />

                                            <Entry 
                                                Placeholder="M" 
                                                WidthRequest="60" 
                                                Text="{Binding Minutes}" />

                                            <Entry 
                                                Placeholder="S" 
                                                WidthRequest="60" 
                                                Text="{Binding Seconds}" />

                                        </HorizontalStackLayout>

                                    </VerticalStackLayout>

                                </Border>

                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                    </CollectionView>

                    <Label Text="Please save this recipe."
                       FontSize="12"
                       TextColor="Gray" />

                    <Button 
                        Text="Save Recipe" 
                        Clicked="SaveRecipe_Clicked"
                        TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                                    Dark={StaticResource PrimaryTextDark}}" />

                </VerticalStackLayout>

            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>