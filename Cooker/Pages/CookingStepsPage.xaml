<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Cooker.Pages.CookingStepsPage"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundColorLight},
                                       Dark={StaticResource PageBackgroundColorDark}}">

    <ScrollView>

        <VerticalStackLayout Padding="20" Spacing="15">

            <Image
                x:Name="RecipeImage"
                HeightRequest="180"
                Aspect="AspectFill"/>

            <Button
                Text="Add Image"
                Clicked="AddImage_Clicked"/>

            <Entry
                x:Name="NameEntry"
                Placeholder="Recipe Name"/>

            <Picker 
                x:Name="CuisinePicker" 
                Title="Cuisine"
                TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                            Dark={StaticResource PrimaryTextDark}}" >
                
                <Picker.Items>
                    <x:String>Chinese</x:String>
                    <x:String>Japanese</x:String>
                    <x:String>Italian</x:String>
                    <x:String>Western</x:String>
                    <x:String>Indian</x:String>
                </Picker.Items>
            </Picker>

            <Editor  
                x:Name="IngredientsEditor"
                Placeholder="Ingredients"/>

            <Editor
                x:Name="StepsEditor"
                Placeholder="Steps"/>

            <Label Text="Add Timer for Step" 
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                               Dark={StaticResource PrimaryTextDark}}" />

            <HorizontalStackLayout Spacing="10">

                <HorizontalStackLayout Spacing="10">
                    <Entry x:Name="HourEntry"
                       Placeholder="Hours"
                       Keyboard="Numeric"
                       WidthRequest="90"
                       TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                                   Dark={StaticResource PrimaryTextDark}}" />

                    <Entry x:Name="MinuteEntry"
                       Placeholder="Minutes"
                       Keyboard="Numeric"
                       WidthRequest="90"
                       TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                                   Dark={StaticResource PrimaryTextDark}}" />

                    <Entry x:Name="SecondEntry"
                       Placeholder="Seconds"
                       Keyboard="Numeric"
                       WidthRequest="90"
                       TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                                   Dark={StaticResource PrimaryTextDark}}" />
                    
                </HorizontalStackLayout>

            </HorizontalStackLayout>

            <Entry 
                x:Name="StepDescriptionEntry" 
                Placeholder="Step description"
                       TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                                   Dark={StaticResource PrimaryTextDark}}" />

            <Button
                Text="Add Timer"
                Clicked="AddTimer_Clicked"
                       TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                                   Dark={StaticResource PrimaryTextDark}}" />

            <CollectionView x:Name="TimerCollection"
                             SelectionMode="Multiple">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            StrokeThickness="1"
                            Padding="10"
                            Margin="5">

                            <VerticalStackLayout Spacing="5">
                                
                                <Label
                                    Text="{Binding StepDescription}"
                                    FontAttributes="Bold"
                                    FontSize="16"
                                    TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                                                Dark={StaticResource PrimaryTextDark}}" />

                                <Label
                                    Text="{Binding TimerSeconds, StringFormat='Time: {0} seconds'}"
                                    FontSize="14"
                                    TextColor="Gray"/>

                                <Button
                                    Text="Delete Timer"
                                    BackgroundColor="Red"
                                    TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                    Dark={StaticResource PrimaryTextDark}}" 
                                    CommandParameter="{Binding .}"
                                    Clicked="DeleteTimer_Clicked"/>
                                
                            </VerticalStackLayout>

                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

            <HorizontalStackLayout
                Margin="0,10,0,0"
                Spacing="10">

                <Button x:Name="MultiDeleteButton"
                    Text="Enable Multi Delete"
                    Clicked="EnableMultiDelete_Clicked"
                    BackgroundColor="LightBlue"
                    TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                                Dark={StaticResource PrimaryTextDark}}" />

                <Button Text="Delete Selected Timers"
                    Clicked="DeleteSelectedTimers_Clicked"
                    BackgroundColor="Red"
                    TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                                Dark={StaticResource PrimaryTextDark}}" />
            </HorizontalStackLayout>

            <Label Text="Tap Enable Multi Delete, then select multiple timers below."
               FontSize="12"
               TextColor="Gray" />

            <Button 
                Text="Save Recipe" 
                Clicked="SaveRecipe_Clicked"
                TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                            Dark={StaticResource PrimaryTextDark}}" />

        </VerticalStackLayout>

    </ScrollView>
</ContentPage>