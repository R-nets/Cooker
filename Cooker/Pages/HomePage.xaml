<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns:converters="clr-namespace:Cooker.Converters"
    xmlns:OnPlatform="clr-namespace:Microsoft.Maui.Controls;assembly=Microsoft.Maui.Controls"
    x:Class="Cooker.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Recipes"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundColorLight},
                                       Dark={StaticResource PageBackgroundColorDark}}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:IsEmptyConverter x:Key="IsEmptyConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>

        <!-- Background image -->
        <Image
            Source="{Binding BackgroundImage}"
            Aspect="AspectFit"
            Opacity="0.25"
            HorizontalOptions="Center"
            VerticalOptions="Center" />


        <BoxView
            x:Name="BackgroundOverlay"
            InputTransparent="True"
            Opacity="0.6"
            BackgroundColor="{AppThemeBinding Light=White, Dark=Black}" />

        <Grid Padding="20">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="FilterRow" Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid x:Name="FilterContainer" Grid.Row="0">

                    <VerticalStackLayout 
                        x:Name="FilterBar" 
                        Spacing="10">

                        <!-- Picker -->
                        <Border
                            Stroke="{DynamicResource BorderColor}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 8"
                            Padding="5">

                            <Picker
                                x:Name="CuisinePicker"
                                Title="Filter Cuisine"
                                SelectedIndexChanged="CuisineChanged"
                                BackgroundColor="Transparent"
                                TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                                                    Dark={StaticResource PrimaryTextDark}}">

                                <Picker.Items>
                                    <x:String>All</x:String>
                                    <x:String>Chinese</x:String>
                                    <x:String>Japanese</x:String>
                                    <x:String>Italian</x:String>
                                    <x:String>Western</x:String>
                                    <x:String>Indian</x:String>
                                </Picker.Items>

                            </Picker>

                        </Border>

                        <!-- SearchBar -->
                        <Border 
                            Stroke="{DynamicResource BorderColor}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 8"
                            Padding="5">

                            <SearchBar
                                Placeholder="Search recipes..."
                                TextChanged="SearchChanged"
                                BackgroundColor="Transparent" />
                        </Border>

                        <!-- Add recipe Button -->
                        <Button
                            Text="＋"
                            Clicked="AddRecipe_Clicked"
                            HorizontalOptions="End"
                            TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                                                Dark={StaticResource PrimaryTextDark}}" />

                    </VerticalStackLayout>

                </Grid>

                <CollectionView
                    x:Name="RecipeCollection"
                    Grid.Row="1"
                    Margin="0,15,0,0"
                    Scrolled="OnCollectionScrolled"
                    SelectionMode="Single"
                    SelectionChanged="RecipeSelected">

                    <CollectionView.ItemTemplate>
                        <DataTemplate>

                            <SwipeView>

                                <SwipeView.RightItems>
                                    <SwipeItems Mode="Execute">
                                        <SwipeItem
                                            Text="Delete"
                                            BackgroundColor="Red"
                                            Invoked="DeleteRecipe" />
                                    </SwipeItems>
                                </SwipeView.RightItems>

                                <Border
                                    StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light=#FFFFFFCC, Dark=#1E1E1ECC}"
                                    Padding="0"
                                    Margin="8"
                                    StrokeShape="RoundRectangle 16">

                                    <Grid RowDefinitions="Auto,*">

                                        <Label
                                            Text="No recipes Image found"
                                            IsVisible="{Binding Recipes.Count, Converter={StaticResource IsEmptyConverter}}"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center"
                                            TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                                        Dark={StaticResource PrimaryTextDark}}"/>

                                        <Image
                                            Source="{Binding ImagePath}"
                                            HeightRequest="160"
                                            Aspect="AspectFill" />

                                        <BoxView 
                                            BackgroundColor="#80000000"
                                            InputTransparent="True" />

                                        <VerticalStackLayout Padding="10" VerticalOptions="End">

                                            <Label
                                                Text="{Binding Name}"
                                                FontSize="18"
                                                FontAttributes="Bold"
                                                TextColor="White" />

                                            <Label
                                                Text="{Binding Cuisine}"
                                                FontSize="12"
                                                TextColor="#DDDDDD" />

                                        </VerticalStackLayout>

                                        <Button
                                            Grid.Column="0"
                                            WidthRequest="66"
                                            HeightRequest="26"
                                            Padding="0"
                                            VerticalOptions="Start"
                                            HorizontalOptions="End"
                                            BackgroundColor="White"
                                            TextColor="Orange"
                                            BorderColor="Orange"
                                            BorderWidth="1"
                                            CornerRadius="20"
                                            Clicked="FavoriteClicked"
                                            CommandParameter="{Binding .}">

                                            <Button.Triggers>
                                                <DataTrigger
                                                    TargetType="Button"
                                                    Binding="{Binding IsFavorite}"
                                                    Value="True">

                                                    <Setter Property="Text" Value="❤" />
                                                    <Setter Property="BackgroundColor" Value="Orange" />
                                                    <Setter Property="TextColor" Value="White" />

                                                </DataTrigger>
                                            </Button.Triggers>

                                            <Button.Text>♡</Button.Text>

                                        </Button>
                                        <Button
                                            Text="Delete"
                                            BackgroundColor="Red"
                                            TextColor="White"
                                            WidthRequest="80"
                                            HeightRequest="30"
                                            HorizontalOptions="End"
                                            VerticalOptions="End"
                                            Margin="10"
                                            Clicked="DeleteRecipe"
                                            CommandParameter="{Binding .}">

                                            <Button.IsVisible>
                                                <OnPlatform x:TypeArguments="x:Boolean">
                                                    <On Platform="WinUI" Value="True" />
                                                    <On Platform="Android" Value="False" />
                                                    <On Platform="iOS" Value="False" />
                                                    <On Platform="MacCatalyst" Value="False" />
                                                </OnPlatform>
                                            </Button.IsVisible>

                                        </Button>
                                    </Grid>
                                </Border>

                            </SwipeView>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
            <ActivityIndicator
                IsRunning="{Binding IsLoading}"
                IsVisible="{Binding IsLoading}"
                VerticalOptions="Center"
                HorizontalOptions="Center"/>
        </Grid>
        <Button
            x:Name="ScrollToTopButton"
            Text="↑"
            WidthRequest="50"
            HeightRequest="50"
            CornerRadius="25"
            FontSize="20"
            IsVisible="False"
            Opacity="0"
            Clicked="ScrollToTop_Clicked"
            BackgroundColor="Orange"
            TextColor="White"
            HorizontalOptions="End"
            VerticalOptions="End"
            Margin="20"
            ZIndex="10"/>
    </Grid>
</ContentPage>