<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns:converters="clr-namespace:Cooker.Converters"
    x:Class="Cooker.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundColorLight},
                                       Dark={StaticResource PageBackgroundColorDark}}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:IsEmptyConverter x:Key="IsEmptyConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid Padding="20" RowDefinitions="Auto,Auto,Auto,*">

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10">

            <Label
                Text="Cooker Recipes"
                FontSize="28"
                FontAttributes="Bold"
                VerticalOptions="Center"
                TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                            Dark={StaticResource PrimaryTextDark}}" />

            <Button
                Grid.Column="1"
                Text="Favorites"
                Clicked="Favorites_Clicked" 
                TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                            Dark={StaticResource PrimaryTextDark}}" />


            <Button
                Grid.Column="2"
                Text="Settings"
                Clicked="Settings_Clicked"
                TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                            Dark={StaticResource PrimaryTextDark}}" />


            <Button
                Grid.Column="3"
                Text="+"
                Clicked="AddRecipe_Clicked"
                TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                            Dark={StaticResource PrimaryTextDark}}" />


        </Grid>

        <Picker
            Grid.Row="1"
            x:Name="CuisinePicker"
            Title="Filter Cuisine"
            Margin="0,15,0,0"
            SelectedIndexChanged="CuisineChanged"
            TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                        Dark={StaticResource PrimaryTextDark}}" >


            <Picker.Items>
                <x:String>All</x:String>
                <x:String>Asian</x:String>
                <x:String>Western</x:String>
                <x:String>Italian</x:String>
                <x:String>Chinese</x:String>
                <x:String>Japanese</x:String>
            </Picker.Items>

        </Picker>

        <SearchBar
            Grid.Row="2"
            Margin="0,15,0,0"
            Placeholder="Search recipes..."
            TextChanged="SearchChanged"/>

        <ActivityIndicator
            IsRunning="True"
            IsVisible="False">

            <ActivityIndicator.Triggers>
                <DataTrigger
                    TargetType="ActivityIndicator"
                    Binding="{Binding Source={x:Reference RecipeCollection}, Path=ItemsSource, Converter={StaticResource IsEmptyConverter}}"
                    Value="True">

                    <Setter Property="IsVisible" Value="True" />
                </DataTrigger>
            </ActivityIndicator.Triggers>
        </ActivityIndicator>

        <CollectionView
            Grid.Row="3"
            Margin="0,15,0,0"
            x:Name="RecipeCollection"
            SelectionMode="Multiple"
            SelectionChanged="RecipeSelected">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <SwipeView>

                        <SwipeView.RightItems>
                            <SwipeItems Mode="Execute">

                                <SwipeItem
                                    Text="Delete"
                                    BackgroundColor="Red"
                                    Invoked="DeleteRecipe" />

                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Border
                            StrokeThickness="1"
                            Padding="10"
                            Margin="5">

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    NumberOfTapsRequired="1"
                                    Tapped="RecipeTapped" />

                                <TapGestureRecognizer
                                    NumberOfTapsRequired="2"
                                    Tapped="RecipeLongPressed" />
                            </Border.GestureRecognizers>

                            <VerticalStackLayout Spacing="8">

                                <Image
                                    Source="{Binding ImagePath}"
                                    HeightRequest="120"
                                    Aspect="AspectFill"/>

                                <Label
                                    Text="{Binding Name}"
                                    FontSize="18"
                                    FontAttributes="Bold"
                                    TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                                                Dark={StaticResource PrimaryTextDark}}" />


                                <Label
                                    Text="{Binding Cuisine}"
                                    FontSize="12"
                                    TextColor="Gray"/>

                                <Button
                                    Text="♡"
                                    BackgroundColor="White"
                                    TextColor="Orange"
                                    BorderColor="Orange"
                                    BorderWidth="1"
                                    CornerRadius="10"
                                    Clicked="FavoriteClicked"
                                    CommandParameter="{Binding .}"
                                    InputTransparent="False"
                                    ZIndex="10">

                                    <Button.Triggers>
                                        <DataTrigger
                                            TargetType="Button"
                                            Binding="{Binding IsFavorite}"
                                            Value="True">
                                            
                                            <Setter Property="Text" Value="❤" />
                                            <Setter Property="BackgroundColor" Value="Orange" />
                                            <Setter Property="TextColor" Value="White" />
                                            
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>

                            </VerticalStackLayout>

                        </Border>

                    </SwipeView>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage>