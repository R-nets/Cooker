<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Cooker.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Grid ColumnDefinitions="*,Auto,Auto">

            <Label
                Text="Cooker Recipes"
                FontSize="28"
                FontAttributes="Bold"/>

            <Button
                Grid.Column="1"
                Text="Settings"
                Clicked="Settings_Clicked"/>

            <Button
                Grid.Column="2"
                Text="+"
                Clicked="AddRecipe_Clicked"/>

        </Grid>

        <Picker
            x:Name="CuisinePicker"
            Title="Filter Cuisine"
            SelectedIndexChanged="CuisineChanged">
            <Picker.Items>
                <x:String>All</x:String>
                <x:String>Asian</x:String>
                <x:String>Western</x:String>
                <x:String>Italian</x:String>
                <x:String>Chinese</x:String>
                <x:String>Japanese</x:String>
            </Picker.Items>
        </Picker>

        <SearchBar
        Placeholder="Search recipes..."
        TextChanged="SearchChanged"/>

        <CollectionView
            x:Name="RecipeCollection"
            SelectionMode="Single"
            SelectionChanged="RecipeSelected">

            <CollectionView.ItemTemplate>

                <DataTemplate>

                    <SwipeView>

                        <SwipeView.RightItems>

                            <SwipeItems>

                                <SwipeItem
                            Text="Delete"
                            BackgroundColor="Red"
                            Invoked="DeleteRecipeSwipe"/>

                            </SwipeItems>

                        </SwipeView.RightItems>
                        <Border
                    Margin="6"
                    Padding="12"
                    Background="#f7f7f7">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>

                            <Grid ColumnDefinitions="80,*">

                                <Image
                                Source="{Binding ImagePath}"
                                HeightRequest="70"
                                WidthRequest="70"/>

                                <VerticalStackLayout Grid.Column="1">

                                    <Label
                                Text="{Binding Name}"
                                FontSize="18"
                                FontAttributes="Bold"/>

                                    <Label
                                Text="{Binding Cuisine}"
                                TextColor="Gray"/>

                                    <Label
                                Text="★ Favorite"
                                IsVisible="{Binding IsFavorite}"
                                TextColor="Orange"/>

                                </VerticalStackLayout>

                            </Grid>

                        </Border>

                    </SwipeView>

                </DataTemplate>

            </CollectionView.ItemTemplate>

        </CollectionView>

    </VerticalStackLayout>

</ContentPage>