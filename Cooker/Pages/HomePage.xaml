<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Cooker.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Grid ColumnDefinitions="*,Auto,Auto">

            <Label
                Text="Cooker Recipes"
                FontSize="28"
                FontAttributes="Bold"/>

            <Button
                Grid.Column="1"
                Text="Settings"
                Clicked="Settings_Clicked"/>

            <Button
                Grid.Column="2"
                Text="+"
                Clicked="AddRecipe_Clicked"/>

        </Grid>

        <Picker
            x:Name="CuisinePicker"
            Title="Filter Cuisine"
            SelectedIndexChanged="CuisineChanged">
            <Picker.Items>
                <x:String>All</x:String>
                <x:String>Asian</x:String>
                <x:String>Western</x:String>
                <x:String>Italian</x:String>
                <x:String>Chinese</x:String>
                <x:String>Japanese</x:String>
            </Picker.Items>
        </Picker>

        <SearchBar
        Placeholder="Search recipes..."
        TextChanged="SearchChanged"/>

        <CollectionView
            x:Name="RecipeCollection"
            SelectionMode="Single"
            SelectionChanged="RecipeSelected">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <SwipeView>

                        <SwipeView.RightItems>
                            <SwipeItems Mode="Execute">

                                <SwipeItem
                        Text="Delete"
                        BackgroundColor="Red"
                        Invoked="DeleteRecipe"/>

                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Border StrokeThickness="1" Padding="10" Margin="5">
                            <VerticalStackLayout>

                                <Image
                                    Source="{Binding ImagePath}"
                                    HeightRequest="120"
                                    Aspect="AspectFill"/>

                                <Label
                                    Text="{Binding Name}"
                                    FontSize="18"
                                    FontAttributes="Bold"/>

                                <Label
                                    Text="{Binding Cuisine}"
                                    FontSize="12"
                                    TextColor="Gray"/>

                                <Button
                                    Text="❤"
                                    Clicked="FavoriteClicked"/>

                            </VerticalStackLayout>
                        </Border>

                    </SwipeView>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </VerticalStackLayout>

</ContentPage>