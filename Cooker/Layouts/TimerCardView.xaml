<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Cooker.Layouts.TimerCardView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Border Padding="10" Margin="0,5">
        <VerticalStackLayout Spacing="10">

            <Label
                Text="{Binding StepDescription}"
                FontAttributes="Bold"
                FontSize="16" 
                TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                            Dark={StaticResource PrimaryTextDark}}" />

            <Label
                Text="{Binding DisplayTime}"
                TextColor="Gray" />

            <HorizontalStackLayout Spacing="10">

                <Button
                    Text="Start Timer"
                    Clicked="StartButton_Clicked" 
                    TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight},
                                Dark={StaticResource PrimaryTextDark}}" />

            </HorizontalStackLayout>
        </VerticalStackLayout>
    </Border>
</ContentView>